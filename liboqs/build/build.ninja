# Object build statements for EXECUTABLE target test_aes


#############################################
# Order-only phony target for test_aes

build cmake_object_order_depends_target_test_aes: phony || cmake_object_order_depends_target_oqs cmake_object_order_depends_target_oqs-internal

build tests/CMakeFiles/test_aes.dir/test_aes.c.o: C_COMPILER__test_aes_Release /home/ewaterhouse2004/liboqs/tests/test_aes.c || cmake_object_order_depends_target_test_aes
  DEFINES = -DOQS_COMPILE_GIT_COMMIT=\"6b390dde2a77e79f887e50cf396e406c0ea7a0f5\" -DOQS_COMPILE_OPTIONS="\"[-march=armv8-a+crypto;-Wa,--noexecstack;-O3;-fomit-frame-pointer;-fdata-sections;-ffunction-sections;-Wl,--gc-sections;-Wbad-function-cast]\""
  DEP_FILE = tests/CMakeFiles/test_aes.dir/test_aes.c.o.d
  FLAGS = -O3 -DNDEBUG -fPIE -fvisibility=hidden -march=armv8-a+crypto -Wa,--noexecstack -O3 -fomit-frame-pointer -fdata-sections -ffunction-sections -Wl,--gc-sections -Wbad-function-cast -std=gnu11
  INCLUDES = -I/home/ewaterhouse2004/liboqs/build/include -I/home/ewaterhouse2004/liboqs/src
  OBJECT_DIR = tests/CMakeFiles/test_aes.dir
  OBJECT_FILE_DIR = tests/CMakeFiles/test_aes.dir
  TARGET_COMPILE_PDB = tests/CMakeFiles/test_aes.dir/
  TARGET_PDB = tests/test_aes.pdb


# =============================================================================
# Link build statements for EXECUTABLE target test_aes


#############################################
# Link the executable tests/test_aes

build tests/test_aes: C_EXECUTABLE_LINKER__test_aes_Release tests/CMakeFiles/test_aes.dir/test_aes.c.o | lib/liboqs.a lib/liboqs-internal.a /usr/lib/aarch64-linux-gnu/libcrypto.so /usr/lib/aarch64-linux-gnu/libcrypto.so || lib/liboqs-internal.a lib/liboqs.a
  FLAGS = -O3 -DNDEBUG
  LINK_FLAGS = -Wl,-z,noexecstack
  LINK_LIBRARIES = lib/liboqs.a  lib/liboqs-internal.a  -lm  /usr/lib/aarch64-linux-gnu/libcrypto.so  /usr/lib/aarch64-linux-gnu/libcrypto.so
  OBJECT_DIR = tests/CMakeFiles/test_aes.dir
  POST_BUILD = :
  PRE_LINK = :
  TARGET_COMPILE_PDB = tests/CMakeFiles/test_aes.dir/
  TARGET_FILE = tests/test_aes
  TARGET_PDB = tests/test_aes.pdb

